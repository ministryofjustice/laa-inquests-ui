{
  "reporter": ["text", "lcov", "html"],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "playwright.config.ts",
    "test",
    "tests",
    "**/*.d.ts",
    "**/*.types.ts",
    "**/*.spec.ts",
    "src/app.ts",
    "src/adaptors/application.ts",
    "src/infrastructure/build/frontend-packages-entry.ts",
    "src/infrastructure/express/middleware/axios/index.ts",
    "src/infrastructure/express/middleware/axios/errors.ts",
    "src/infrastructure/express/middleware/index.ts",
    "src/infrastructure/express/middleware/security",
    "src/infrastructure/express/middleware/nunjucks/setupNunjucks.ts",
    "src/infrastructure/express/routes/**/*.ts",
    "src/infrastructure/express/session/*.ts",
    "src/infrastructure/config"
  ],
  "all": true,
  "sourceMap": true,
  "check-coverage": true,
  "lines": 20,
  "functions": 60,
  "branches": 70,
  "statements": 20
}
